# OpenClaw Dashboard 环境变量配置

# ========================================
# 认证配置
# ========================================

# 管理员密码（建议修改默认密码）
# 默认值: openclaw123
OPENCLAW_ADMIN_PASSWORD=openclaw123

# JWT 密钥（用于 Token 验证）
# 建议使用强随机字符串
JWT_SECRET=openclaw-jwt-secret-change-in-production-2026

# 认证 URL（用于 JWT 验证）
AUTH_URL=http://localhost:3000

# ========================================
# OpenClaw 配置
# ========================================

# OpenClaw 配置路径（可选）
# 默认值: ~/.openclaw
OPENCLAW_HOME=/path/to/openclaw

# ========================================
# 其他配置
# ========================================

# Node.js 环境
NODE_ENV=development

# GitHub Token（用于技能商店，可选）
GITHUB_TOKEN=ghp_xxx
